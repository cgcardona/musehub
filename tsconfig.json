{
  "compilerOptions": {
    "target": "ES2024",
    "lib": ["ES2024", "ESNext", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": false,
    "allowJs": true,
    "checkJs": false,
    "allowImportingTsExtensions": true
  },
  "include": [
    "musehub/templates/musehub/static/js/**/*.ts"
  ]
}
