# MuseHub environment configuration
# Copy this file to .env and fill in the values.
#
# For LOCAL DEV:  use the defaults below + docker-compose.override.yml
# For PRODUCTION: generate strong values for all secrets (see comments)

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL password (must match POSTGRES_PASSWORD in docker-compose.yml)
# Production: openssl rand -hex 16
# Local dev : musehub  (rejected by startup guard in production)
DB_PASSWORD=musehub

# The app connects via the internal Docker network (postgres:5432).
# The host-side port is 5434 — avoids clashing with local Postgres (5432)
# and agentception (5433). Use this for host-side Alembic / tests:
#   DATABASE_URL=postgresql+asyncpg://musehub:<DB_PASSWORD>@localhost:5434/musehub

# ── Authentication ────────────────────────────────────────────────────────────
# JWT signing secret — generate with: openssl rand -hex 32
# REQUIRED in production — app refuses to start without it.
ACCESS_TOKEN_SECRET=

# ── CORS ─────────────────────────────────────────────────────────────────────
# JSON array of allowed origins.
# Local dev : ["http://localhost:10003", "muse://"]
# Production: ["https://musehub.ai", "https://www.musehub.ai"]
CORS_ORIGINS=["http://localhost:10003", "muse://"]

# ── MCP allowed origins (DNS-rebinding protection) ───────────────────────────
# Production: ["musehub.ai", "www.musehub.ai"]
# MUSEHUB_ALLOWED_ORIGINS=["musehub.ai", "www.musehub.ai"]

# ── AWS S3 / CloudFront (optional) ───────────────────────────────────────────
# Required only if you serve binary assets from S3.
# AWS_REGION=us-east-1
# AWS_S3_ASSET_BUCKET=musehub-assets
# AWS_CLOUDFRONT_DOMAIN=assets.musehub.ai

# ── Webhook encryption (optional) ────────────────────────────────────────────
# Generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# WEBHOOK_SECRET_KEY=

# ── Debug ─────────────────────────────────────────────────────────────────────
# NEVER set DEBUG=true in production — it exposes Swagger/ReDoc.
DEBUG=false
