# MuseHub environment configuration
# Copy this file to .env and fill in the values.
#
# Required for production; optional for local dev (defaults listed below).

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL password (must match POSTGRES_PASSWORD in docker-compose.yml)
DB_PASSWORD=musehub

# The app connects via the internal Docker network (postgres:5432).
# The host-side port is 5434 — avoids clashing with local Postgres (5432)
# and the agentception container (5433).
# Use this URL when running tests or Alembic migrations directly from the host:
#   DATABASE_URL=postgresql+asyncpg://musehub:musehub@localhost:5434/musehub
#   alembic upgrade head
#   make test

# ── Authentication ────────────────────────────────────────────────────────────
# JWT signing secret — generate with: openssl rand -hex 32
ACCESS_TOKEN_SECRET=

# ── CORS ─────────────────────────────────────────────────────────────────────
# JSON array of allowed origins. Defaults to empty (restrictive) in prod.
CORS_ORIGINS=["http://localhost:10003", "muse://"]

# ── AWS S3 / CloudFront (optional) ───────────────────────────────────────────
# Required only if you serve binary assets from S3.
# AWS_REGION=eu-west-1
# AWS_S3_ASSET_BUCKET=muse-assets
# AWS_CLOUDFRONT_DOMAIN=assets.example.com

# ── Webhook encryption (optional) ────────────────────────────────────────────
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# WEBHOOK_SECRET_KEY=

# ── Debug ─────────────────────────────────────────────────────────────────────
DEBUG=false
